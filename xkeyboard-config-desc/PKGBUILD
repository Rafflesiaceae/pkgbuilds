pkgname=xkeyboard-config-desc
pkgver=a2f64784
pkgrel=2
pkgdesc="X keyboard configuration files for custom desc layout"
arch=('any')
license=('GPL')
depends=('xkeyboard-config')
source=(desc)
sha1sums=('SKIP')

pkgver() {
    sha256sum desc | cut -c1-8
}

package() {
    install -Dm644 "$srcdir/desc" "$pkgdir/usr/share/xkeyboard-config-2/symbols/desc"
}

